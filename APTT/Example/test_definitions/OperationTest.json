{
    "production": "APTT.Example.Production",
    "namespace": "NHSINTERFACES",
    "tests": [
        {
            "name": "MyOperation",
            "class": "APTT.Example.Operation",
            "interactions": [
                {
                    "name": "Test Example Request",
                    "request": {
                        "class": "APTT.Example.Request",
                        "properties": {
                            "Name": "Testing",
                            "Gender": "M",
                            "FavouriteColours": [
                                "Blue",
                                "Green",
                                "Red"
                            ],
                            "MainAddress": {
                                "HouseNumber": 55,
                                "Streets": [
                                    "Street1",
                                    "Street2"
                                ]
                            },
                            "OtherAddresses": [
                                {
                                    "HouseNumber": 66,
                                    "Streets": [
                                        "Street3"
                                    ]
                                }
                            ],
                            "NamedAddresses": {
                                "Main": {
                                    "HouseNumber": 33,
                                    "Streets": [
                                        "Street 4"
                                    ]
                                }
                            }
                        }
                    },
                    "response": {
                        "class": "APTT.Example.Response",
                        "validators": {
                            "Name": {
                                "validator": "TextValidator",
                                "options": {
                                    "contains": "rUs"
                                }
                            },
                            "OtherAddresses[0].Streets[0]": {
                                "validator": "TextValidator",
                                "options": {
                                    "contains": "eet3"
                                }
                            }
                        },
                        "properties": {
                            "Name": "r",
                            "FavouriteColours": [
                                "Blue",
                                "Green"
                            ],
                            "MainAddress": {
                                "HouseNumber": 55,
                                "Streets": [
                                    "Street1",
                                    "Street2"
                                ]
                            },
                            "OtherAddresses": [
                                {
                                    "HouseNumber": 66,
                                    "Streets": [
                                        "Street3"
                                    ]
                                }
                            ],
                            "NamedAddresses": {
                                "Main": {
                                    "HouseNumber": 33,
                                    "Streets": [
                                        "Street 4"
                                    ]
                                }
                            }
                        }
                    }
                }
            ]
        }
    ]
}